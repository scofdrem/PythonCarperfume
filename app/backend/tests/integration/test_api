    def test_create_rating(self):
        """Test POST /api/ratings"""
        token = self._get_auth_token()
        
        # Create aroma first
        aroma_response = self.client.post('/api/aromas', json={
            'name': 'Rated Aroma',
            'description': 'An aroma to be rated',
            'notes': ['test']
        }, headers={'Authorization': f'Bearer {token}'})
        aroma_id = json.loads(aroma_response.data)['aroma']['id']
        
        # Create rating
        response = self.client.post('/api/ratings', json={
            'aroma_id': aroma_id,
            'rating': 4.5,
            'review': 'Excellent fragrance!'
        }, headers={'Authorization': f'Bearer {token}'})
        data = json.loads(response.data)
        
        self.assertEqual(response.status_code, 201)
        self.assertIn('rating', data)
        self.assertEqual(data['rating']['rating'], 4.5)
    
    def test_create_invalid_rating(self):
        """Test POST /api/ratings with invalid rating value"""
        token = self._get_auth_token()
        
        response = self.client.post('/api/ratings', json={
            'aroma_id': 1,
            'rating': 6.0,  # Invalid: should be <= 5
            'review': 'Test'
        }, headers={'Authorization': f'Bearer {token}'})
        data = json.loads(response.data)
        
        self.assertEqual(response.status_code, 400)
        self.assertIn('error', data)


